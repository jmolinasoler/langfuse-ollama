# Langfuse credentials — https://cloud.langfuse.com → Project Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# EU region (default). Change for US/JP/HIPAA:
# https://us.cloud.langfuse.com | https://jp.cloud.langfuse.com | https://hipaa.cloud.langfuse.com
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Ollama endpoint (default local)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: pre-set defaults
DEFAULT_MODEL=llama3.1
DEFAULT_SYSTEM_PROMPT=You are a helpful assistant.
DEFAULT_USER_ID=julio
